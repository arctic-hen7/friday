# Friday — root .env (copy to .env and fill in).
# Loaded by both the orchestrator (via `bun --env-file=../.env`) and the
# Eleven IL (via its custom loader).

# ============================================================================
# Eleven IL (interaction-layers/eleven)
# ============================================================================

# Required: ElevenLabs API credentials and the Speech Engine you created via
# `bun run create-speech-engine` (inside interaction-layers/eleven).
ELEVENLABS_API_KEY=
ELEVENLABS_SPEECH_ENGINE_ID=

# IL HTTP port (used by the Express server).
ELEVEN_PORT=5000

# Where the Eleven IL finds the orchestrator. Smart defaults (no need to set):
#   - NODE_ENV=production:  http://orchestrator:6000  (Docker DNS)
#   - else (local dev):     http://localhost:6000
# ORCHESTRATOR_URL=http://localhost:6000

# Optional — Speech Engine debug logging.
SPEECH_ENGINE_DEBUG=false

# Used only by the create-speech-engine script in interaction-layers/eleven:
ELEVENLABS_VOICE_ID=
ELEVENLABS_VOICE_SPEED=1.05
SPEECH_ENGINE_NAME=Friday Voice Agent
SPEECH_ENGINE_LANGUAGE=en
PUBLIC_GATEWAY_URL=https://your-ngrok-or-public-domain.example.com

# ============================================================================
# Orchestrator
# ============================================================================

# HTTP/WS port. In compose this is set explicitly; locally it defaults to 6000.
ORCHESTRATOR_PORT=6000

# Lite agent (Gemini Flash Lite) — pick ONE auth path:
#   - Dev:  set GEMINI_API_KEY (AI Studio key)
#   - Prod: set VERTEX_PROJECT + VERTEX_LOCATION and use ADC
GEMINI_API_KEY=
VERTEX_PROJECT=
VERTEX_LOCATION=

# Lite model id. Defaults to gemini-2.5-flash-lite.
LITE_MODEL=gemini-2.5-flash-lite

# Where SQLite lives. Defaults:
#   - prod (in container): /data/friday.db
#   - dev (local):         ./data/friday.db (under orchestrator/)
# FRIDAY_DB_PATH=./data/friday.db

# How the orchestrator reaches the Primary container.
PRIMARY_CONTAINER=friday-primary
PODMAN_BIN=podman

# ============================================================================
# Compose-only knobs
# ============================================================================

# Path to the host Podman API socket, mounted into the orchestrator container
# in production. Override if your socket isn't at the rootless default.
# PODMAN_SOCKET=/run/user/1000/podman/podman.sock
